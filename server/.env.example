PORT=3000
GEMINI_API_KEY=GEMINI_API_KEY_HERE
ETHERFUSE_API_KEY=ETHERFUSE_SANDBOX_KEY_HERE
ETHERFUSE_BASE_URL=https://api.sand.etherfuse.com
CORS_ORIGIN=http://localhost:5173

GOOGLE_CLIENT_ID=GOOGLE_OAUTH_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=GOOGLE_OAUTH_CLIENT_SECRET_HERE
OAUTH_CALLBACK_URL=http://localhost:3000/auth/google/callback
WEB_BASE_URL=http://localhost:5173
# Must include the SPA base path in prod (e.g. https://host/S37/) — the web bootstrap only runs
# the PKCE code→token exchange on a trusted landing (pathname must match the SPA base path).
# Mismatch = login silently fails. Dev SPA is served at "/", so the root URL is correct here.
WEB_LOGIN_SUCCESS_URL=http://localhost:5173
WEB_LOGIN_FAILURE_URL=http://localhost:5173/?login=failed
SESSION_SECRET=GENERATE_A_32_PLUS_CHAR_RANDOM_STRING_HERE

# Email verification (signup flow). Leave RESEND_API_KEY blank in dev to log the
# 6-digit code to the server console instead of sending a real email.
RESEND_API_KEY=
# Resend test sender (without a verified domain, you can only send to your own Resend account email address; if you set a verified sender email, you can send to any email address).
EMAIL_FROM=FractaPay <onboarding@resend.dev>

DATABASE_URL=mysql://fractapay:fractapay@localhost:3306/fractapay

