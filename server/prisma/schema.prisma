// Prisma talks to MariaDB through the `mysql` provider.
// Note: `@db.Json` columns are stored as LONGTEXT under the hood on MariaDB.
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}

enum Token {
  TESOURO
}

enum PixKeyType {
  EVP
  CPF
  CNPJ
  EMAIL
  PHONE
}

enum PaymentMessageRole {
  ASSISTANT
  USER
}

enum PaymentStatus {
  CREATED
  FUNDED
  COMPLETED
  FAILED
  REFUNDED
  CANCELED
}

enum PaymentMethod {
  PIX
}

model User {
  id                    String        @id @default(cuid())
  email                 String        @unique
  emailVerified         DateTime?
  name                  String?
  avatarUrl             String?       @db.Text
  companyName           String?
  onboardingCompletedAt DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  accounts     OAuthAccount[]
  destinations Destination[]
  payments     Payment[]
}

model Destination {
  id         String     @id @default(cuid())
  userId     String
  name       String     @db.VarChar(200)
  token      Token
  pixKey     String     @db.Text
  pixKeyHash String     @db.VarChar(64)
  pixKeyType PixKeyType
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentDestinations PaymentDestination[]

  @@unique([userId, pixKeyHash])
  @@index([userId])
}

model Payment {
  id                  String        @id @default(cuid())
  userId              String        @db.VarChar(500)
  status              PaymentStatus @default(CREATED)
  token               Token
  method              PaymentMethod @default(PIX)
  amount              String        @db.VarChar(50)
  feeAmount           String        @db.VarChar(50)
  feePercentage       String        @db.VarChar(2)
  tokenAmount         String        @db.VarChar(50)
  externalId String       @db.VarChar(500)
  customerId String       @db.VarChar(500)
  address      String      @db.VarChar(200)
  exchangeRate String      @db.VarChar(50)
  transactionSignature         String?       @db.VarChar(500)
  pixData             String?       @db.VarChar(2000)
  isRecurring         Boolean       @default(false)
  errorMessage        String?       @db.VarChar(5000)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        PaymentItem[]
  destinations PaymentDestination[]
  messages     PaymentMessage[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
}

model PaymentItem {
  id          String   @id @default(cuid())
  paymentId   String   @db.VarChar(500)
  amount      String   @db.VarChar(50)
  description String?  @db.VarChar(400)
  createdAt   DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model PaymentDestination {
  id            String     @id @default(cuid())
  paymentId     String     @db.VarChar(500)
  destinationId String?    @db.VarChar(500)
  name          String     @db.VarChar(200)
  token         Token
  pixKey        String     @db.VarChar(2000)
  pixKeyType    PixKeyType
  percentage    Int
  amount        String     @db.VarChar(50)
  createdAt     DateTime   @default(now())

  payment     Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  destination Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)

  @@index([paymentId])
}

model PaymentMessage {
  id        String   @id @default(cuid())
  paymentId String   @db.VarChar(500)
  role      PaymentMessageRole
  text      String   @db.VarChar(5000)
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

model OAuthAccount {
  id                String    @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

